# Copy this file to .env  (cp .env.example .env) and fill in your key.
# Next.js loads .env automatically — there is no separate backend process.
# .env is git-ignored — never commit it.

# API key issued to your Siymo account, of the form siymo_<48-hex>.
# Stays server-side only (used by the /api/* route handlers).
SIYMO_OTP_API_KEY=siymo_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL of the Siymo OTP service.
SIYMO_OTP_BASE_URL=https://otp.siymo.com

# Port the Next.js app listens on (`npm run dev` / `npm start`). Default: 3000.
PORT=3000
