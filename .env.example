# Copy this file to .env  (cp .env.example .env) and fill in your key.
# Next.js loads .env automatically — there is no separate backend process.
# .env is git-ignored — never commit it.

# API key issued to your Siymo account, of the form siymo_<48-hex>.
# Stays server-side only (used by the /api/* route handlers).
SIYMO_OTP_API_KEY=siymo_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL of the Siymo OTP service.
SIYMO_OTP_BASE_URL=https://otp.siymo.com

# Port the Next.js app listens on (`npm run dev` / `npm start`). Default: 3000.
PORT=3000

# --- PostHog analytics (autocapture clicks/scroll, session replay, heatmaps) ---
# Project API key from PostHog → Project settings. Public (NEXT_PUBLIC_*), safe
# to ship to the browser. Leave blank to disable analytics entirely (local dev).
NEXT_PUBLIC_POSTHOG_KEY=
# Where "open in PostHog" links point. US cloud: https://us.posthog.com
# EU cloud: https://eu.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
# Only set these if your project is on EU cloud (defaults are US):
#   NEXT_PUBLIC_POSTHOG_INGEST_HOST=https://eu.i.posthog.com
#   NEXT_PUBLIC_POSTHOG_ASSETS_HOST=https://eu-assets.i.posthog.com
