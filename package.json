{
  "name": "siymo-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "docker:publish": "docker buildx build --platform linux/amd64,linux/arm64 --build-arg NEXT_PUBLIC_POSTHOG_KEY --build-arg NEXT_PUBLIC_POSTHOG_HOST --build-arg NEXT_PUBLIC_POSTHOG_INGEST_HOST --build-arg NEXT_PUBLIC_POSTHOG_ASSETS_HOST -t registry.inadullaev.com/siymo-web:latest --push .",
    "docker:tag": "bash -c 'docker buildx imagetools create -t registry.inadullaev.com/siymo-web:$0 registry.inadullaev.com/siymo-web:${1:-latest}'"
  },
  "dependencies": {
    "@siymo/otp-browser": "^2.1.0",
    "@siymo/otp-server": "^2.1.0",
    "lottie-react": "^2.4.0",
    "next": "^14.2.18",
    "posthog-js": "^1.372.10",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
